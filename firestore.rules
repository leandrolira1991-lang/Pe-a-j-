rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "leandrolira1991@gmail.com" ||
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products Rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isVerifiedAdmin() && isValidId(productId);
      allow delete: if isVerifiedAdmin();
    }

    // Settings Rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isVerifiedAdmin() && isValidId(settingId);
    }

    // Combo Rules
    match /combos/{comboId} {
      allow read: if true;
      allow create, update: if isVerifiedAdmin() && isValidId(comboId);
      allow delete: if isVerifiedAdmin();
    }

    // Banner Rules
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update: if isVerifiedAdmin() && isValidId(bannerId);
      allow delete: if isVerifiedAdmin();
    }
  }
}
